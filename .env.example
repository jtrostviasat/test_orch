# Copy to .env and adjust for your environment: `cp .env.example .env`
# Defaults below work for the bundled single-host docker compose stack.

# --- App ---
APP_ENV=development
SECRET_KEY=change-me
WORKER_HOST_ID=worker_host_01
# Grace period before the admin host-status poll emits its sentinel.
HOST_POLL_GRACE_SECONDS=4.0
# Resiliency: a host is considered dead after this many seconds without a
# heartbeat; the backend sweep marks it offline and fails its orphaned runs.
HEARTBEAT_TIMEOUT_SECONDS=90.0
MAINTENANCE_SWEEP_SECONDS=30.0

# --- PostgreSQL (central state DB) ---
# Either set DATABASE_URL outright, or leave it blank and use the parts below.
# DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=test_orch
POSTGRES_PASSWORD=test_orch
POSTGRES_DB=test_orch

# --- Celery / RabbitMQ ---
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- InfluxDB ---
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=changeme-influx-token
INFLUX_ORG=test_orch
INFLUX_BUCKET=test_logs

# --- LDAP (login) ---
LDAP_HOST=ldap.corp.example.com
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=dc=corp,dc=example,dc=com
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=corp,dc=example,dc=com

# --- Quali CloudShell ---
QUALI_API_URL=https://cloudshell.corp.example.com/api
QUALI_API_TOKEN=changeme-quali-token

# --- Artifactory ---
ARTIFACTORY_URL=https://artifactory.corp.example.com/artifactory
ARTIFACTORY_REPO=test-artifacts
ARTIFACTORY_USER=ci-user
ARTIFACTORY_TOKEN=changeme-artifactory-token

# --- Docker (rootless) ---
# Match your UID's rootless socket; see SETUP_AND_TESTING.md.
DOCKER_HOST=unix:///run/user/1000/docker.sock
DOCKER_HOST_SOCK=/run/user/1000/docker.sock
TEST_RUNS_DIR=/tmp/test_runs
